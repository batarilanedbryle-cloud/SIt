@model IEnumerable<Batarilan_Exercise1.Models.SitIn>
@{
    ViewData["Title"] = "Current Sit-Ins";
}

<div class="page-header">
    <div>
        <h3>Current Sit-Ins</h3>
        <p class="page-subtitle">Students currently in the lab</p>
    </div>
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Purpose</th>
                    <th>Time In</th>
                    <th>Status</th>
                    <th style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr><td colspan="5" style="text-align:center; padding:2.5rem; color:var(--text-muted);">No active sit-ins at the moment</td></tr>
                }
                else
                {
                    foreach (var s in Model)
                    {
                        <tr>
                            <td style="font-weight:500;">@s.StudentName</td>
                            <td>@s.Purpose</td>
                            <td style="color:var(--text-muted); font-size:0.85rem;">@s.TimeIn.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span style="background:#e6f7f0; color:var(--success); padding:0.15rem 0.6rem; border-radius:20px; font-size:0.72rem; font-weight:600;">@s.Status</span></td>
                            <td style="text-align:right;">
                                <form asp-controller="Admin" asp-action="TimeOut" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Time Out</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
