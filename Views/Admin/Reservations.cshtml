@model IEnumerable<Batarilan_Exercise1.Models.Reservation>
@{
    ViewData["Title"] = "Reservations";
    var statusFilter  = ViewBag.StatusFilter as string ?? "";
    int pending       = (int)(ViewBag.PendingCount  ?? 0);
    int approved      = (int)(ViewBag.ApprovedCount ?? 0);
    int denied        = (int)(ViewBag.DeniedCount   ?? 0);
    int total         = pending + approved + denied;
}

<div class="page-header">
    <div>
        <h3>📅 Reservations</h3>
        <p class="page-subtitle">Manage student lab reservation requests</p>
    </div>
    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

@if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"]   != null) { <div class="alert alert-danger">@TempData["Error"]</div>   }

<!-- Stat cards -->
<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:0.85rem; margin-bottom:1.25rem;">
    <a asp-action="Reservations" style="text-decoration:none;">
        <div class="stat-card" style="border-bottom:3px solid var(--navy-light); cursor:pointer;">
            <div class="stat-label">Total</div>
            <div class="stat-value">@total</div>
            <div class="stat-sub">All requests</div>
        </div>
    </a>
    <a asp-action="Reservations" asp-route-status="Pending" style="text-decoration:none;">
        <div class="stat-card" style="border-bottom:3px solid var(--accent); cursor:pointer;">
            <div class="stat-label">Pending</div>
            <div class="stat-value" style="color:#b57f18;">@pending</div>
            <div class="stat-sub" style="color:#b57f18; font-weight:500;">Awaiting action →</div>
        </div>
    </a>
    <a asp-action="Reservations" asp-route-status="Approved" style="text-decoration:none;">
        <div class="stat-card" style="border-bottom:3px solid var(--success); cursor:pointer;">
            <div class="stat-label">Approved</div>
            <div class="stat-value" style="color:var(--success);">@approved</div>
            <div class="stat-sub" style="color:var(--success); font-weight:500;">Confirmed →</div>
        </div>
    </a>
    <a asp-action="Reservations" asp-route-status="Denied" style="text-decoration:none;">
        <div class="stat-card" style="border-bottom:3px solid var(--danger); cursor:pointer;">
            <div class="stat-label">Denied</div>
            <div class="stat-value" style="color:var(--danger);">@denied</div>
            <div class="stat-sub" style="color:var(--danger); font-weight:500;">Rejected →</div>
        </div>
    </a>
</div>

<!-- PC Availability Grid -->
<div class="card" style="margin-bottom:1.25rem;">
    <div class="card-header" style="display:flex; align-items:center; justify-content:space-between;">
        <span>🖥 PC Availability by Room</span>
        <select id="adminRoomSelect" class="form-control" style="width:auto; min-width:180px; font-size:0.85rem;" onchange="adminLoadPcGrid()">
            <option value="">— Select a room —</option>
            <option value="Lab 524">Lab 524</option>
            <option value="Lab 526">Lab 526</option>
            <option value="Lab 528">Lab 528</option>
            <option value="Lab 530">Lab 530</option>
            <option value="Lab 542">Lab 542</option>
            <option value="Lab 544">Lab 544</option>
        </select>
    </div>
    <div class="card-body">
        <div id="adminPcPanel" style="display:none;">
            <!-- Legend -->
            <div style="display:flex; gap:1.2rem; align-items:center; margin-bottom:0.85rem; font-size:0.8rem; color:var(--text-muted); flex-wrap:wrap;">
                <span style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="width:14px; height:14px; border-radius:3px; background:#e6f7f0; border:2px solid var(--success); display:inline-block;"></span> Available
                </span>
                <span style="display:flex; align-items:center; gap:0.4rem;">
                    <span style="width:14px; height:14px; border-radius:3px; background:#fdeaea; border:2px solid var(--danger); display:inline-block;"></span> Unavailable
                </span>
                <span id="adminLoadingPcs" style="display:none; color:var(--text-muted);">⏳ Loading…</span>
            </div>
            <div id="adminPcGrid" style="display:grid; grid-template-columns:repeat(10,1fr); gap:0.5rem;"></div>
            <div id="adminPcSummary" style="margin-top:0.75rem; font-size:0.82rem; color:var(--text-muted);"></div>
        </div>
        <div id="adminPcPlaceholder" style="text-align:center; color:var(--text-muted); font-size:0.85rem; padding:1rem 0;">
            Select a room above to view PC availability.
        </div>
    </div>
</div>

<!-- Filter tabs -->
<div style="display:flex; gap:0.4rem; margin-bottom:1rem; flex-wrap:wrap;">
    @{
        var tabs = new[] { ("", "All"), ("Pending", "⏳ Pending"), ("Approved", "✅ Approved"), ("Denied", "✕ Denied") };
        foreach (var (val, label) in tabs)
        {
            bool active = statusFilter == val;
            <a asp-action="Reservations" asp-route-status="@val"
               style="padding:0.4rem 1rem; border-radius:20px; font-size:0.82rem; font-weight:600; border:1.5px solid var(--border); @(active ? "background:var(--navy); color:white; border-color:var(--navy);" : "background:white; color:var(--text-muted);")">
                @label
            </a>
        }
    }
</div>

<div class="card">
    <div class="card-body" style="padding:0;">
        @if (!Model.Any())
        {
            <div style="text-align:center; padding:3rem 2rem;">
                <div style="font-size:2.5rem; opacity:0.3; margin-bottom:0.75rem;">📅</div>
                <p style="color:var(--text-muted); margin:0;">No reservations found@(!string.IsNullOrEmpty(statusFilter) ? $" with status \"{statusFilter}\"" : "").</p>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Purpose</th>
                        <th>Date</th>
                        <th>Room</th>
                        <th>PC</th>
                        <th style="text-align:center;">Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td style="font-weight:600;">@r.StudentName</td>
                            <td style="color:var(--text-muted);">@r.Purpose</td>
                            <td style="font-size:0.85rem;">@r.ReservationDate.ToString("MMM dd, yyyy")</td>
                            <td style="font-size:0.85rem;">@r.Room</td>
                            <td style="font-size:0.85rem;">@r.PcNumber</td>
                            <td style="text-align:center;">
                                @if (r.Status == "Pending")
                                {
                                    <span style="background:var(--accent-lt); color:#b57f18; font-size:0.72rem; font-weight:600; padding:0.2rem 0.65rem; border-radius:20px;">⏳ Pending</span>
                                }
                                else if (r.Status == "Approved")
                                {
                                    <span style="background:#e6f7f0; color:var(--success); font-size:0.72rem; font-weight:600; padding:0.2rem 0.65rem; border-radius:20px;">✅ Approved</span>
                                }
                                else
                                {
                                    <span style="background:#fdeaea; color:var(--danger); font-size:0.72rem; font-weight:600; padding:0.2rem 0.65rem; border-radius:20px;">✕ Denied</span>
                                }
                            </td>
                            <td style="text-align:right;">
                                <div style="display:flex; gap:0.35rem; justify-content:flex-end;">
                                    @if (r.Status == "Pending")
                                    {
                                        <form asp-action="ApproveReservation" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-success btn-sm">✅ Approve</button>
                                        </form>
                                        <form asp-action="DenyReservation" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm">✕ Deny</button>
                                        </form>
                                    }
                                    <form asp-action="DeleteReservation" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm"
                                                onclick="return confirm('Delete this reservation?');">🗑</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<script>
function adminLoadPcGrid() {
    var room = document.getElementById("adminRoomSelect").value;
    var panel = document.getElementById("adminPcPanel");
    var placeholder = document.getElementById("adminPcPlaceholder");
    var grid = document.getElementById("adminPcGrid");
    var loading = document.getElementById("adminLoadingPcs");
    var summary = document.getElementById("adminPcSummary");

    if (!room) {
        panel.style.display = "none";
        placeholder.style.display = "block";
        return;
    }

    panel.style.display = "block";
    placeholder.style.display = "none";
    loading.style.display = "inline";
    grid.innerHTML = "";
    summary.textContent = "";

    fetch("/Admin/GetPcAvailability?room=" + encodeURIComponent(room))
        .then(function(r) { return r.json(); })
        .then(function(unavailableList) {
            loading.style.display = "none";
            grid.innerHTML = "";
            var availableCount = 0;

            for (var i = 1; i <= 50; i++) {
                var isUnavailable = unavailableList.indexOf(i) !== -1;
                if (!isUnavailable) availableCount++;

                var cell = document.createElement("div");
                cell.style.cssText = "aspect-ratio:1; border-radius:7px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px; padding:3px;"
                    + (isUnavailable
                        ? "background:#fdeaea; border:2px solid #d63a3a; opacity:0.75;"
                        : "background:#e6f7f0; border:2px solid #1e8a5e;");
                cell.title = "PC " + i + " — " + (isUnavailable ? "Unavailable" : "Available");

                var icon = document.createElement("span");
                icon.style.cssText = "font-size:0.72rem;";
                icon.textContent = isUnavailable ? "🔴" : "✅";

                var label = document.createElement("span");
                label.style.cssText = "font-size:0.65rem; font-weight:700; color:" + (isUnavailable ? "#d63a3a" : "#1e8a5e") + ";";
                label.textContent = "PC " + i;

                cell.appendChild(icon);
                cell.appendChild(label);
                grid.appendChild(cell);
            }

            summary.textContent = availableCount + " available · " + (50 - availableCount) + " unavailable out of 50 PCs";
        })
        .catch(function() {
            loading.style.display = "none";
            grid.innerHTML = "<p style=\"color:var(--danger); font-size:0.82rem;\">Failed to load PC status.</p>";
        });
}
</script>
