<!-- ── Announcements ── -->
<div class="card">
    <div class="card-header bg-primary">📢 Announcements</div>
    <div class="card-body" style="padding:0;">
        @if (!announcements.Any())
        {
            <p class="text-muted" style="margin:1.25rem; font-size:0.875rem;">No announcements at this time.</p>
        }
        else
        {
            foreach (var a in announcements)
            {
                <div style="padding:1rem 1.25rem; border-bottom:1px solid var(--border);">
                    <div style="display:flex; align-items:baseline; justify-content:space-between; gap:1rem; margin-bottom:0.3rem;">
                        <strong style="font-size:0.9rem; color:var(--text);">@a.Title</strong>
                        <small class="text-muted" style="white-space:nowrap; font-size:0.78rem;">
                            @a.DatePosted.ToString("MMM dd, yyyy")
                        </small>
                    </div>
                    <p style="margin:0; font-size:0.875rem; color:var(--text-muted); line-height:1.6;">@a.Message</p>
                </div>
            }
        }
    </div>
</div>
