@{
    ViewData["Title"] = "Register";
    Layout = null;
}
@model UserAccount
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — CCS Sit-in System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Serif+Display&display=swap" rel="stylesheet" />
</head>
<body style="margin:0;">
<div class="auth-layout">

    <!-- Left Panel -->
    <div class="auth-panel-left">
        <img src="~/images/signup.png" style="width:300px; max-width:100%; position:relative; z-index:1; border-radius:12px; opacity:0.9;" />
        <div style="margin-top:1.5rem; text-align:center; position:relative; z-index:1;">
            <p style="color:rgba(255,255,255,0.6); font-size:0.85rem; max-width:280px; line-height:1.7; margin:0 auto;">
                Join the CCS community and manage your sit-in sessions with ease.
            </p>
        </div>
        <div style="position:absolute; bottom:2rem; left:0; right:0; text-align:center;">
            <a href="/Account/Login" style="color:rgba(255,255,255,0.55); font-size:0.8rem;">Already have an account? Sign in →</a>
        </div>
    </div>

    <!-- Right Panel (scrollable) -->
    <div class="auth-panel-right" style="align-items:flex-start; overflow-y:auto; padding:2.5rem 3rem;">
        <div style="width:100%; max-width:500px; margin:0 auto;">
            <div style="margin-bottom:2rem;">
                <h2 style="font-family:'DM Serif Display',serif; font-size:1.75rem; color:var(--navy); margin-bottom:0.3rem;">Create Account</h2>
                <p style="font-size:0.875rem; color:var(--text-muted);">Fill in your details to register</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post">

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.75rem;">
                    <div>
                        <label class="form-label">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                    </div>
                    <div>
                        <label class="form-label">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Dela Cruz" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Middle Name</label>
                    <input asp-for="MiddleName" class="form-control" placeholder="(Optional)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">ID Number</label>
                    <input asp-for="IdNumber" class="form-control" placeholder="e.g. 2024-00001" />
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.75rem;">
                    <div>
                        <label class="form-label">Course</label>
                        <input asp-for="Course" class="form-control" placeholder="e.g. BSCS" />
                    </div>
                    <div>
                        <label class="form-label">Year Level</label>
                        <input asp-for="CourseLevel" class="form-control" placeholder="e.g. 2nd Year" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="Your home address" />
                </div>

                <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:1.25rem;">
                    <div>
                        <label class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" />
                    </div>
                </div>

                <div style="text-align:center;">
                    <button type="submit" class="btn btn-primary w-100" style="padding:0.65rem; display:block;">Create Account</button>
                </div>
            </form>
        </div>
    </div>

</div>
</body>
</html>
